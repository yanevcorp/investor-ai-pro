# Local dev: points at the backend running on your machine (npm run dev in /backend)
REACT_APP_API_URL=http://localhost:5000/api

# Production (Vercel): set this in the frontend project's Environment
# Variables (Project Settings -> Environment Variables), not in a
# committed .env file — CRA bakes REACT_APP_* vars in at build time.
# Point it at your deployed backend project's URL, e.g.:
# REACT_APP_API_URL=https://investor-ai-pro-api.vercel.app/api
