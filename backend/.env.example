NODE_ENV=development
PORT=5000

# Local MongoDB or Atlas connection string
MONGO_URI=mongodb://localhost:27017/investor-ai-pro

# Used to sign JWTs — replace with a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:3000

# Real market data providers
# Finnhub: real-time quotes + company profile. Free tier: 60 req/min.
FINNHUB_API_KEY=replace_with_your_finnhub_key
# Alpha Vantage: fundamentals (OVERVIEW endpoint). Free tier: 25 req/DAY —
# results are cached permanently on the Stock document in Mongo after the
# first fetch per symbol, so this quota is barely touched in normal use.
ALPHA_VANTAGE_API_KEY=replace_with_your_alpha_vantage_key
# NewsAPI: company headlines. Free "Developer" tier is dev-only per their
# ToS — it does not permit production/commercial deployments.
NEWS_API_KEY=replace_with_your_newsapi_key
# Anthropic: powers the natural-language screener (parses free-text queries
# like "Намери подценени tech компании с дълг под 20%" into structured
# filters). Without this set, the screener silently falls back to a plain
# symbol/name match.
ANTHROPIC_API_KEY=replace_with_your_anthropic_key

# --- Production (Vercel) ---
# Set these in the backend project's Environment Variables (Project
# Settings -> Environment Variables), not in a committed .env file:
#   NODE_ENV=production
#   MONGO_URI=<your Atlas connection string>
#   JWT_SECRET=<a long random string, different from local/dev>
#   JWT_EXPIRES_IN=7d
#   CLIENT_URL=https://investor-ai-pro.vercel.app   (your deployed frontend URL — no trailing slash)
#   FINNHUB_API_KEY=<your key>
#   ALPHA_VANTAGE_API_KEY=<your key>
#   NEWS_API_KEY=<your key>
#   ANTHROPIC_API_KEY=<your key>
# PORT is not needed on Vercel; the platform handles the listener.
